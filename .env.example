# PageChat backend environment example.
# Copy this file to backend/.env and fill in your own values.

# development | production
APP_ENV=development

# Required in production. Use long random values.
JWT_SECRET=
MODEL_SETTINGS_SECRET=

# Optional environment fallback model route.
# Product usage should prefer configuring model providers in the UI.
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.6-plus
LLM_FLASH_MODEL=qwen3.6-flash
LLM_PLUS_MODEL=qwen3.6-plus
ALLOW_ENV_MODEL_FALLBACK=false

# Agent runtime.
AGENT_RUNTIME_MODE=flat_tool_loop

# OCR / VLM environment fallback.
# Product usage should prefer configuring OCR in the UI.
OCR_API_KEY=
OCR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OCR_MODEL=qwen3.5-ocr
OCR_DEFAULT_ENGINE_TYPE=openai_compatible_ocr
OCR_OPENAI_BASE_URL=
OCR_OPENAI_MODEL=
OCR_OPENAI_API_KEY=
OCR_PADDLEOCR_JOB_URL=https://paddleocr.aistudio-app.com/api/v2/ocr/jobs
OCR_PADDLEOCR_MODEL=PP-OCRv6
OCR_PADDLEOCR_API_KEY=

# OCR and indexing limits.
OCR_MAX_CONCURRENCY=20
OCR_RATE_LIMIT_RPS=15
OCR_MAX_RETRIES=2
OCR_TIMEOUT_SECONDS=60
PAGEINDEX_MODE=balanced
PAGEINDEX_MAX_CONCURRENT_JOBS=1
PAGEINDEX_MAX_INDEX_SECONDS=600

# Chat attachments.
CHAT_ATTACHMENT_MAX_BYTES=10485760
CHAT_ATTACHMENT_MAX_PER_MESSAGE=6

# Optional web search.
ANYSEARCH_API_KEY=
